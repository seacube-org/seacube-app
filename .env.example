# SeaCube App — environment template.
# Copy to .env.development / .env.production and set the API URL.
#
# Only PUBLIC values belong here: every EXPO_PUBLIC_* variable is inlined into
# the shipped client bundle and is therefore NOT secret. Never put API keys,
# tokens, or passwords in these files.
#
# Production builds MUST use an https:// URL (enforced at runtime in
# constants/Constants.ts) — a plaintext http endpoint would expose JWTs to MITM.
EXPO_PUBLIC_API_URL=https://api.example.com
